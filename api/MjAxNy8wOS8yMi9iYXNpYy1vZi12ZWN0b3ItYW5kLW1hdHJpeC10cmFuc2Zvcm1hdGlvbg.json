=\"E2-GYREPAGELLAMAIN-6F\" d=\"M514 237c0 -150 -110 -257 -264 -257c-129 0 -218 96 -218 237c0 149 101 252 247 252c137 0 235 -97 235 -232zM421 200c0 136 -68 236 -160 236c-88 0 -136 -65 -136 -185c0 -142 66 -238 164 -238c81 0 132 72 132 187Z\"></path>\n<path stroke-width=\"1\" id=\"E2-GYREPAGELLAMAIN-73\" d=\"M391 148c0 -98 -93 -168 -224 -168c-46 0 -85 7 -137 24c8 40 11 70 11 139h30v-41c0 -50 52 -85 125 -85c71 0 121 38 121 92c0 38 -19 59 -64 69c-68 15 -121 31 -148 43c-46 21 -68 55 -68 103c0 90 71 145 187 145c41 0 77 -7 130 -25c-3 -31 -4 -55 -5 -113h-28v23 c0 47 -51 82 -118 82c-61 0 -96 -28 -96 -78c0 -46 27 -66 109 -82c88 -17 121 -28 147 -54c20 -20 28 -43 28 -74Z\"></path>\n<path stroke-width=\"1\" id=\"E2-GYREPAGELLANORMAL-1D703\" d=\"M493 489c-7 -151 -76 -316 -148 -403c-50 -60 -113 -97 -166 -97c-84 0 -113 77 -106 236c8 184 81 335 174 420c48 45 93 66 136 66c82 0 116 -83 110 -222zM392 319c-16 8 -44 11 -112 11c-71 0 -98 -3 -120 -12c-6 -32 -10 -64 -11 -95c-5 -119 2 -196 62 -196 c30 0 58 18 79 49c35 52 76 142 102 243zM416 467c6 124 3 206 -60 206c-24 0 -47 -8 -62 -23c-38 -42 -88 -150 -120 -268c18 -7 47 -10 115 -10c66 0 97 3 117 10c6 28 9 57 10 85Z\"></path>\n</defs>\n<g stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" transform=\"matrix(1 0 0 -1 0 0)\" aria-hidden=\"true\">\n <use xlink:href=\"#E2-GYREPAGELLANORMAL-1D44E\" x=\"0\" y=\"0\"></use>\n <use xlink:href=\"#E2-GYREPAGELLAMAIN-20D7\" x=\"443\" y=\"47\"></use>\n <use xlink:href=\"#E2-GYREPAGELLAMAIN-22C5\" x=\"666\" y=\"0\"></use>\n<g transform=\"translate(1169,0)\">\n <use xlink:href=\"#E2-GYREPAGELLANORMAL-1D44F\" x=\"0\" y=\"0\"></use>\n <use xlink:href=\"#E2-GYREPAGELLAMAIN-20D7\" x=\"452\" y=\"298\"></use>\n</g>\n <use xlink:href=\"#E2-GYREPAGELLAMAIN-3D\" x=\"1910\" y=\"0\"></use>\n <use xlink:href=\"#E2-GYREPAGELLAMAIN-2016\" x=\"2949\" y=\"0\"></use>\n <use xlink:href=\"#E2-GYREPAGELLANORMAL-1D44E\" x=\"3325\" y=\"0\"></use>\n <use xlink:href=\"#E2-GYREPAGELLAMAIN-2016\" x=\"3770\" y=\"0\"></use>\n <use xlink:href=\"#E2-GYREPAGELLAMAIN-2016\" x=\"4146\" y=\"0\"></use>\n <use xlink:href=\"#E2-GYREPAGELLANORMAL-1D44F\" x=\"4523\" y=\"0\"></use>\n <use xlink:href=\"#E2-GYREPAGELLAMAIN-2016\" x=\"4986\" y=\"0\"></use>\n<g transform=\"translate(5529,0)\">\n <use xlink:href=\"#E2-GYREPAGELLAMAIN-63\"></use>\n <use xlink:href=\"#E2-GYREPAGELLAMAIN-6F\" x=\"444\" y=\"0\"></use>\n <use xlink:href=\"#E2-GYREPAGELLAMAIN-73\" x=\"991\" y=\"0\"></use>\n</g>\n <use xlink:href=\"#E2-GYREPAGELLANORMAL-1D703\" x=\"7111\" y=\"0\"></use>\n</g>\n</svg></p>\n<p><img src=\"http://img.frankorz.com/59c275ef5ad97.png\" alt=\"\" class=\"φcx\"></p>\n<h3 id=\"叉积（cross-product）\">叉积（Cross Product）<a title=\"#叉积（cross-product）\" href=\"#叉积（cross-product）\"></a></h3>\n<p>将向量相乘得到一个正交向量（垂直于向量a和向量b）</p>\n<p style=\"text-align:center\"><svg xmlns:xlink=\"http://www.w3.org/1999/xlink\" width=\"20.699ex\" height=\"6.176ex\" style=\"vertical-align: -2.505ex;\" viewBox=\"0 -1580.7 8911.9 2659.1\" role=\"img\" focusable=\"false\" xmlns=\"http://www.w3.org/2000/svg\" aria-labelledby=\"MathJax-SVG-1-Title\">\n<title id=\"MathJax-SVG-1-Title\">\\begin{array}{l}{a \\times b=-b \\times a} \\\\ {\\|a \\times b\\|=\\|a\\|\\|b\\| \\sin \\theta}\\end{array}</title>\n<defs aria-hidden=\"true\">\n<path stroke-width=\"1\" id=\"E1-GYREPAGELLANORMAL-1D44E\" d=\"M406 85c-82 -68 -123 -96 -146 -96c-15 0 -24 14 -24 37c0 16 2 33 6 51l29 127c-55 -78 -95 -125 -138 -162c-37 -32 -74 -53 -95 -53c-19 0 -34 34 -34 77c0 80 31 199 75 288c25 49 57 79 120 110c27 13 47 18 75 18c27 0 46 -4 85 -19l33 18l10 -9l-92 -379 c-1 -3 -1 -6 -1 -10c0 -16 5 -24 15 -24c15 0 30 9 62 36c5 4 6 5 13 11zM319 414c-43 15 -62 19 -85 19c-49 0 -73 -18 -97 -76c-35 -83 -61 -194 -61 -258c0 -27 6 -40 18 -40c33 0 96 61 151 145c33 51 52 103 74 210Z\"></path>\n<path stroke-width=\"1\" id=\"E1-GYREPAGELLAMAIN-D7\" d=\"M547 59c-9 -5 -17 -12 -24 -19s-13 -15 -19 -23l-191 191l-191 -191c-5 8 -12 16 -19 23s-15 14 -23 19l191 191l-191 191c8 5 16 12 23 19s14 15 19 2